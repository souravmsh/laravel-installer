{
    "name": "souravmsh/laravel-installer",
    "description": "A sleek and easy-to-use web-based installer for Laravel applications.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "installer",
        "install",
        "configuration",
        "settings",
        "setup",
        "wizard",
        "deployment",
        "souravmsh",
        "codekernel"
    ],
    "authors": [
        {
            "name": "Shohrab Hossain",
            "email": "sourav.diubd@gmail.com",
            "homepage": "https://github.com/souravmsh",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.1"
    },
    "autoload": {
        "psr-4": {
            "Souravmsh\\Installer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Souravmsh\\Installer\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Souravmsh\\Installer\\InstallerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/souravmsh/laravel-installer/issues",
        "source": "https://github.com/souravmsh/laravel-installer"
    }
}
